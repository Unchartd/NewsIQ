# ─────────────────────────────────────────────
# NewsIQ Environment Variables
# Copy to .env and fill in real values
# ─────────────────────────────────────────────

# App
APP_NAME=NewsIQ
APP_VERSION=0.1.0
DEBUG=true

# Database (local Docker)
DATABASE_URL=postgresql+asyncpg://newsiq:newsiq@localhost:5432/newsiq

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=newsiq-dev-key

# Auth
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# AI Models
OPENAI_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
SUMMARIZATION_MODEL=gemini-2.5-flash

# News APIs
NEWSAPI_KEY=
GNEWS_API_KEY=

# Frontend / CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3002"]
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# SMTP Settings
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@newsiq.io
SMTP_FROM_NAME=NewsIQ

