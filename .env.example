# ─────────────────────────────────────────────────────────────────────────────
# NewsIQ — Environment Variables Reference
# Copy to .env and fill in real values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=NewsIQ
APP_VERSION=0.1.0
DEBUG=true
BACKEND_SERVICE_ROLE=monolith

# ── Database — Neon PostgreSQL (Production) ───────────────────────────────────
# Neon provides two endpoints:
#   1. Pooled (PgBouncer) — use for the app (DATABASE_URL)
#   2. Direct             — use for Alembic migrations (DATABASE_DIRECT_URL)
#
# Neon pooled format:
#   postgresql+asyncpg://<user>:<pass>@<region>.neon.tech/<dbname>?pgbouncer=true&sslmode=require
# Neon direct format:
#   postgresql+asyncpg://<user>:<pass>@ep-<id>.neon.tech/<dbname>?sslmode=require
#
DATABASE_URL=postgresql+asyncpg://newsiq:newsiq@localhost:5432/newsiq
DATABASE_DIRECT_URL=postgresql+asyncpg://newsiq:newsiq@localhost:5432/newsiq
DATABASE_SSL=false

# ── Redis — Upstash (Production) ─────────────────────────────────────────────
# Upstash does not support multiple database indices.
# Provision 3 separate Upstash Redis instances (all on free tier).
#
# Upstash format: rediss://:TOKEN@HOST:PORT
#   REDIS_URL           → Application cache (story:*, trending:*, rate_limit:*, session:*)
#   CELERY_BROKER_URL   → Celery task queue broker
#   CELERY_RESULT_BACKEND → Celery task result storage
#
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Object Storage — Cloudflare R2 ───────────────────────────────────────────
# STORAGE_BACKEND: r2 | s3 | minio | local
# For local dev, set STORAGE_BACKEND=local (uses LOCAL_STORAGE_PATH directory)
# For R2: create a bucket in Cloudflare dashboard, generate R2 API token
#
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/storage

# R2 credentials (required when STORAGE_BACKEND=r2)
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=newsiq-prod
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=https://assets.newsiq.io

# S3 / MinIO credentials (used when STORAGE_BACKEND=s3 or minio)
S3_ENDPOINT=
S3_BUCKET=newsiq
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# ── OAuth — Google ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# ── AI Models ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY_EMBEDDING=
GEMINI_API_KEY_SYNTH=
GROQ_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=

EMBEDDING_MODEL=text-embedding-004
SUMMARIZATION_MODEL=gemini-2.5-flash

# ── News APIs ─────────────────────────────────────────────────────────────────
NEWSAPI_KEY=
GNEWS_API_KEY=

# ── Vector Database — Qdrant (local, keep on VM) ─────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Search — Meilisearch (local, keep on VM) ──────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=newsiq-dev-key

# ── Observability — Langfuse ──────────────────────────────────────────────────
# Langfuse Cloud: https://cloud.langfuse.com (free: 50k observations/month)
# Self-hosted: http://langfuse:3000 (requires Docker profile=dev)
#
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Error Tracking — Sentry ───────────────────────────────────────────────────
SENTRY_DSN=

# ── Frontend / CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3002"]
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-NEWSIQ
NEXT_PUBLIC_POSTHOG_TOKEN=phc_mock_token_newsiq
NEXT_PUBLIC_ANALYTICS_DEBUG=true

# ── Reverse Proxy / SSL (Production Only) ─────────────────────────────────────
API_DOMAIN=api.newsiq.online
ADMIN_API_DOMAIN=admin-api.newsiq.online
ACME_EMAIL=hello.newsiq@gmail.com

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@newsiq.io
SMTP_FROM_NAME=NewsIQ

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc
